generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Society {
  id             String   @id @default(cuid())
  name           String
  address        String
  city           String
  pincode        String
  totalFlats     Int      @default(0)
  maintenanceAmt Float    @default(0)
  dueDayOfMonth  Int      @default(10)
  lateFee        Float    @default(0)
  upiId          String?
  bankDetails    String?
  planTier       String   @default("starter")
  openingBalance Float    @default(0)
  createdAt      DateTime @default(now())

  flats              Flat[]
  users              User[]
  bills              MaintenanceBill[]
  expenses           Expense[]
  complaints         Complaint[]
  notices            Notice[]
  visitors           Visitor[]
  parkingSlots       ParkingSlot[]
  facilities         Facility[]
  facilityBookings   FacilityBooking[]
  meetingMinutes     MeetingMinutes[]
  emergencyContacts  EmergencyContact[]
  polls              Poll[]
  documents          Document[]
  activityLogs       ActivityLog[]
  notifications      Notification[]
  vendors            Vendor[]
}

model Flat {
  id            String   @id @default(cuid())
  societyId     String
  flatNumber    String
  wing          String?
  floor         Int?
  ownerName     String
  tenantName    String?
  contact       String
  email         String?
  vehicleNumber String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  society       Society           @relation(fields: [societyId], references: [id])
  bills         MaintenanceBill[]
  reminders     ReminderLog[]
  parkingSlots  ParkingSlot[]
  visitors      Visitor[]
  users         User[]

  @@unique([societyId, flatNumber])
}

model MaintenanceBill {
  id            String    @id @default(cuid())
  flatId        String
  societyId     String
  amount        Float
  lateFee       Float     @default(0)
  period        String // "2026-03" format
  dueDate       DateTime
  status        String    @default("pending") // pending | paid | partial
  paidAt        DateTime?
  paidVia       String? // cash | upi | neft | cheque
  paidAmount    Float?
  receiptNote   String?
  receiptNumber String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  flat    Flat    @relation(fields: [flatId], references: [id])
  society Society @relation(fields: [societyId], references: [id])

  @@unique([flatId, period])
}

model ReminderLog {
  id          String   @id @default(cuid())
  flatId      String
  billId      String?
  channel     String // whatsapp | sms
  sentAt      DateTime @default(now())
  status      String // sent | failed | delivered
  messageBody String
  flat        Flat     @relation(fields: [flatId], references: [id])
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  phone     String?
  role      String   @default("member") // chairman | secretary | treasurer | member
  societyId String?
  flatId    String?
  createdAt DateTime @default(now())
  society   Society? @relation(fields: [societyId], references: [id])
  flat      Flat?    @relation(fields: [flatId], references: [id])
}

model Expense {
  id        String   @id @default(cuid())
  societyId String
  title     String
  amount    Float
  category  String // maintenance | repair | salary | utilities | other
  paidTo    String?
  paidOn    DateTime
  notes     String?
  vendorId  String?
  vendor    Vendor?  @relation(fields: [vendorId], references: [id])
  createdAt DateTime @default(now())
  society   Society  @relation(fields: [societyId], references: [id])
}

model Complaint {
  id          String   @id @default(cuid())
  societyId   String
  flatNumber  String
  raisedBy    String
  title       String
  description String
  category    String   @default("general") // plumbing | electrical | cleanliness | security | parking | general
  status      String   @default("open") // open | in_progress | resolved | closed
  priority    String   @default("medium") // low | medium | high | urgent
  resolution  String?
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  society     Society  @relation(fields: [societyId], references: [id])
}

model Notice {
  id        String   @id @default(cuid())
  societyId String
  title     String
  body      String
  category  String   @default("general") // general | event | maintenance | emergency | meeting
  postedBy  String
  isPinned  Boolean  @default(false)
  expiresAt DateTime?
  createdAt DateTime @default(now())
  society   Society  @relation(fields: [societyId], references: [id])
}

// ===== NEW MODELS =====

model Visitor {
  id          String    @id @default(cuid())
  societyId   String
  flatId      String?
  flatNumber  String
  visitorName String
  phone       String?
  purpose     String    // delivery | guest | service | cab | other
  vehicleNo   String?
  entryTime   DateTime  @default(now())
  exitTime    DateTime?
  approvedBy  String?
  notes       String?
  status      String    @default("in") // in | out
  isPreApproved Boolean @default(false)
  expectedAt  DateTime? // Only if pre-approved
  createdAt   DateTime  @default(now())
  society     Society   @relation(fields: [societyId], references: [id])
  flat        Flat?     @relation(fields: [flatId], references: [id])
}

model ParkingSlot {
  id         String   @id @default(cuid())
  societyId  String
  slotNumber String
  slotType   String   @default("car") // car | bike | ev
  wing       String?
  flatId     String?
  isAssigned Boolean  @default(false)
  vehicleNo  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  society    Society  @relation(fields: [societyId], references: [id])
  flat       Flat?    @relation(fields: [flatId], references: [id])

  @@unique([societyId, slotNumber])
}

model Facility {
  id          String   @id @default(cuid())
  societyId   String
  name        String
  description String?
  capacity    Int?
  ratePerHour Float    @default(0)
  isActive    Boolean  @default(true)
  rules       String?
  createdAt   DateTime @default(now())
  society     Society  @relation(fields: [societyId], references: [id])
  bookings    FacilityBooking[]
}

model FacilityBooking {
  id          String   @id @default(cuid())
  societyId   String
  facilityId  String
  bookedBy    String
  flatNumber  String
  date        DateTime
  startTime   String   // "09:00"
  endTime     String   // "11:00"
  purpose     String?
  status      String   @default("confirmed") // confirmed | cancelled
  amount      Float    @default(0)
  createdAt   DateTime @default(now())
  society     Society  @relation(fields: [societyId], references: [id])
  facility    Facility @relation(fields: [facilityId], references: [id])
}

model MeetingMinutes {
  id          String   @id @default(cuid())
  societyId   String
  title       String
  date        DateTime
  meetingType String   @default("general") // agm | sgm | committee | general
  attendees   String?
  agenda      String
  minutes     String
  decisions   String?
  recordedBy  String
  createdAt   DateTime @default(now())
  society     Society  @relation(fields: [societyId], references: [id])
}

model EmergencyContact {
  id          String   @id @default(cuid())
  societyId   String
  name        String
  phone       String
  category    String   // plumber | electrician | ambulance | fire | police | hospital | pest_control | other
  address     String?
  isAvailable Boolean  @default(true)
  notes       String?
  createdAt   DateTime @default(now())
  society     Society  @relation(fields: [societyId], references: [id])
}

model Poll {
  id          String   @id @default(cuid())
  societyId   String
  title       String
  description String?
  options     String   // JSON array of options
  votes       String   @default("{}") // JSON object {optionIndex: count}
  voters      String   @default("[]") // JSON array of flatNumbers that voted
  createdBy   String
  status      String   @default("active") // active | closed
  closesAt    DateTime?
  createdAt   DateTime @default(now())
  society     Society  @relation(fields: [societyId], references: [id])
}

model Document {
  id          String   @id @default(cuid())
  societyId   String
  title       String
  category    String   @default("general") // bylaws | rules | noc | minutes | financial | general
  fileName    String
  fileUrl     String
  fileSize    Int?
  uploadedBy  String
  createdAt   DateTime @default(now())
  society     Society  @relation(fields: [societyId], references: [id])
}

// ===== PHASE 1: AUDIT LOG & NOTIFICATIONS =====

model ActivityLog {
  id          String   @id @default(cuid())
  societyId   String
  userId      String?
  userName    String
  action      String   // created | updated | deleted | paid | generated | sent | resolved
  module      String   // bill | expense | complaint | notice | visitor | flat | poll | meeting | facility | parking | document | settings
  targetId    String?
  targetLabel String?  // human readable e.g. "Flat A-101", "Bill March 2026"
  details     String?  // JSON string with old/new values or extra context
  ipAddress   String?
  createdAt   DateTime @default(now())
  society     Society  @relation(fields: [societyId], references: [id])

  @@index([societyId, createdAt])
  @@index([module])
}

model Notification {
  id          String    @id @default(cuid())
  societyId   String
  userId      String?   // null = broadcast to all
  type        String    // bill_due | bill_paid | complaint_update | notice_new | poll_new | visitor_entry | late_fee | reminder
  title       String
  message     String
  link        String?   // e.g. "/complaints" or "/maintenance"
  isRead      Boolean   @default(false)
  createdAt   DateTime  @default(now())
  society     Society   @relation(fields: [societyId], references: [id])

  @@index([societyId, userId, isRead])
  @@index([createdAt])
}

model Vendor {
  id             String    @id @default(cuid())
  societyId      String
  name           String
  category       String    // electrical | plumbing | lift | pest | security | cleaning | other
  contactPerson  String?
  phone          String?
  email          String?
  gstNumber      String?
  address        String?
  hasAMC         Boolean   @default(false)
  amcStartDate   DateTime?
  amcEndDate     DateTime?
  amcAmount      Float?
  rating         Int       @default(0) // 1-5
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  
  society        Society   @relation(fields: [societyId], references: [id])
  expenses       Expense[]
}
